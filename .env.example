# CrediRisk Environment Template
# Copy to '.env' and fill in values before starting the cluster

# --- Database ---
POSTGRES_USER=credirisk
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=credirisk_db
DATABASE_URL="postgresql://credirisk:change_me_strong_password@db:5432/credirisk_db"

# --- Auth ---
SECRET_KEY=replace_with_256_bit_random_secret

# --- OpenAI ---
OPENAI_API_KEY=""

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- CORS (comma-separated allowed origins) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Observability ---
SENTRY_DSN=""
LOG_LEVEL=INFO

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_TABLEAU_REPORT_URL=""
VITE_SENTRY_DSN=""
